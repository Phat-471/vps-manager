{
  "name": "vps-management-tool",
  "version": "1.1.2",
  "description": "Công cụ quản lý VPS dễ dàng cho người mới bắt đầu",
  "main": "server/server.js",
  "bin": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "build:bin": "pkg . --targets node18-linux-x64 --output dist/vps-manager"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "keywords": [
    "vps",
    "server-management",
    "ssh",
    "linux"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "express": "^4.18.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.1",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  }
}
